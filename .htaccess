Options -Indexes
DirectoryIndex public/index.php index.php

<IfModule mod_rewrite.c>
  RewriteEngine On

  # If host docroot points to project root, serve app from /public.
  RewriteCond %{REQUEST_URI} !^/public/
  RewriteCond %{REQUEST_URI} !^/pay/
  RewriteCond %{REQUEST_URI} !^/includes/
  RewriteCond %{REQUEST_URI} !^/config/
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)$ public/$1 [L,QSA]

  # Handle direct /index.php when docroot is project root.
  RewriteRule ^index\.php$ public/index.php [L,QSA]
</IfModule>
